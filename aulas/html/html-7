/* 
Seletores CSS:
Seletor de Classe -> .
Seletor de Id -> #
Seletor de Elemento -> Tag html
*/

body{
    background-color: gray; /* Cor de Fundo */
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; /* Estilo da Fonte */
    font-size: 16px; /* Tamanho da Fonte */
    margin: 0px; /* Margem */
    padding: 0px; /* Borda Interna */
    text-align: center; /* Alinhamento do Texto */
}
