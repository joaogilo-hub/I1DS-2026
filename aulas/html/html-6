<!DOCTYPE html>
<html lang="ept-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTML | Aula 05</title>
    <link rel="stylesheet" href="Aula-05.css" />
</head>
<body> 
    <div id="formuláro">
        <h1>Cadastro de Alunos</h1>
            <form method="get" action=""> <!-- Elemento de Formulário -->
                <label for="inNome">Nome:</label>
                <input type="text" name="inNome"/>
                <br />

                <label for="inEmail">E-mail:</label>
                <input type="email" name="inEmail"/>
                <br />

                <label for="inSenha">Senha:</label>
                <input type="password" name="inSenha"/>
                <br />

                <label for="inData">Data:</label>
                <input type="date" name="inData"/>
                <br />

                 <label for="inDataCad">DataCad:</label>
                <input type="datetime-local" name="inDataCad"/>
                <br />

                 <label for="inCep">Cep:</label>
                <input type="number" step="1" name="inCep"/>
                <br />

                 <label for="inTermo">Aceita os Termos e Condições? </label>
                <input type="checkbox" name="inTermo"/>
                <br />

            </form>
    </div>
</body>
</html>